generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(EDITOR)
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─── PRODUCTS ────────────────────────────────────────────────────────────────

model Product {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  description     String             @db.Text
  shortDesc       String?
  price           Decimal            @db.Decimal(10, 2)
  salePrice       Decimal?           @db.Decimal(10, 2)
  sku             String             @unique
  inStock         Boolean            @default(true)
  featured        Boolean            @default(false)
  newArrival      Boolean            @default(false)
  images          Json               // [{ url: string, alt: string, isPrimary: boolean }]
  dimensions      Json?              // { width, height, depth, unit }
  weight          Decimal?           @db.Decimal(8, 2)
  materials       String[]
  colors          String[]
  finishes        String[]
  tags            String[]
  metaTitle       String?
  metaDesc        String?
  sortOrder       Int                @default(0)
  publishedAt     DateTime?
  categoryId      String
  category        Category           @relation(fields: [categoryId], references: [id])
  collectionItems CollectionProduct[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([slug])
  @@index([featured])
  @@index([categoryId])
  @@index([newArrival])
  @@index([publishedAt])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  parent      Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[] @relation("SubCategories")
  products    Product[]
  sortOrder   Int        @default(0)
  visible     Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Collection {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?             @db.Text
  bannerImage String?
  featured    Boolean             @default(false)
  items       CollectionProduct[]
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model CollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
}

// ─── CMS PAGE BUILDER ────────────────────────────────────────────────────────

model Page {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  sections    Section[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published])
}

model Section {
  id        String      @id @default(cuid())
  pageId    String
  page      Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  type      SectionType
  label     String?
  sortOrder Int         @default(0)
  visible   Boolean     @default(true)
  content   Json
  styles    Json
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([pageId])
}

enum SectionType {
  HERO_BANNER
  FEATURED_PRODUCTS
  CATEGORY_GRID
  COLLECTION_SHOWCASE
  IMAGE_TEXT_SPLIT
  FULL_WIDTH_IMAGE
  TEXT_CONTENT
  STATS_COUNTER
  TESTIMONIALS_CAROUSEL
  TEAM_GRID
  GALLERY_GRID
  VIDEO_EMBED
  NEWSLETTER_SIGNUP
  CONTACT_FORM
  FAQ_ACCORDION
  CUSTOM_HTML
}

// ─── GLOBAL THEME ────────────────────────────────────────────────────────────

model Theme {
  id              String   @id @default(cuid())
  name            String   @default("GreatHouses Default")
  colorPrimary    String   @default("#1a1a1a")
  colorSecondary  String   @default("#c9a96e")
  colorAccent     String   @default("#f5f0e8")
  colorBackground String   @default("#ffffff")
  colorText       String   @default("#1a1a1a")
  colorMuted      String   @default("#6b7280")
  colorBorder     String   @default("#e5e7eb")
  colorError      String   @default("#ef4444")
  fontHeading     String   @default("Playfair Display")
  fontBody        String   @default("Jost")
  fontSizeBase    Int      @default(16)
  lineHeight      String   @default("1.6")
  letterSpacing   String   @default("0em")
  borderRadius    String   @default("4px")
  buttonStyle     String   @default("sharp")
  cardShadow      String   @default("sm")
  navStyle        String   @default("fixed")
  navBgColor      String   @default("#ffffff")
  navTextColor    String   @default("#1a1a1a")
  navHeight       Int      @default(72)
  logoUrl         String?
  logoMaxHeight   Int      @default(48)
  faviconUrl      String?
  customCSS       String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── CONTENT ─────────────────────────────────────────────────────────────────

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  title     String?
  company   String?
  avatar    String?
  content   String   @db.Text
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  role      String
  bio       String?  @db.Text
  image     String?
  linkedin  String?
  instagram String?
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  filename  String
  url       String
  publicId  String
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  alt       String?
  folder    String?  @default("greathouses")
  tags      String[]
  createdAt DateTime @default(now())
}

model Inquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String        @db.Text
  productId String?
  status    InquiryStatus @default(NEW)
  notes     String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  active       Boolean  @default(true)
  token        String   @unique @default(cuid())
  subscribedAt DateTime @default(now())
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  label     String?
  group     String?
  updatedAt DateTime @updatedAt
}
